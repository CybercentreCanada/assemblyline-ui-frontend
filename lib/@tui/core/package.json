{
  "name": "@tui/core",
  "version": "4.0.4",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "cookie": "^1.0.0",
    "js-cookie": "^3",
    "lodash-es": ">=4.17.23 <5"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4",
    "tsdown": "^0.15.12"
  },
  "peerDependencies": {
    "@mui/icons-material": "^7",
    "@mui/material": "^7",
    "i18next": ">=25",
    "notistack": ">=3",
    "react": "^19.2",
    "react-i18next": ">=16",
    "zustand": ">=5"
  }
}
