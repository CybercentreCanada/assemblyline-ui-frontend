{
  "global": {
    "components": {
      "MuiPaper": {
        "styleOverrides": {
          "elevation": {
            "backgroundImage": "none"
          }
        }
      },
      "MuiTab": {
        "styleOverrides": {
          "root": {
            "minWidth": "145px"
          }
        }
      }
    }
  },
  "light": {
    "palette": {
      "mode": "light",
      "background": {
        "default": "#FAFAFA",
        "paper": "#FFFFFF"
      },
      "primary": {
        "main": "#0062BF"
      },
      "secondary": {
        "main": "#5189A3"
      }
    }
  },
  "dark": {
    "palette": {
      "mode": "dark",
      "background": {
        "default": "#202020",
        "paper": "#303030"
      },
      "primary": {
        "main": "#7DA1DB"
      },
      "secondary": {
        "main": "#C0DEEC"
      },
      "divider": "#414141"
    }
  }
}
